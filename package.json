{
  "name": "nutritrack-pwa",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "Tracker di calorie e macro - PWA vanilla TypeScript installabile iOS-first",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,css}\" \"test/**/*.ts\" \"*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,css}\" \"test/**/*.ts\" \"*.{ts,js,json,md}\"",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build"
  },
  "dependencies": {
    "@zxing/library": "^0.21.3",
    "vite-plugin-pwa": "^0.20.5",
    "workbox-build": "^7.1.1",
    "workbox-cacheable-response": "^7.1.0",
    "workbox-core": "^7.1.0",
    "workbox-expiration": "^7.1.0",
    "workbox-precaching": "^7.1.0",
    "workbox-routing": "^7.1.0",
    "workbox-strategies": "^7.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^22.5.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "jsdom": "^25.0.1",
    "prettier": "^3.9.4",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.63.0",
    "vite": "^5.4.0",
    "vitest": "^2.1.9"
  }
}
